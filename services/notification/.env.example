# Notification Service Environment Variables

# Server
NODE_ENV=development
PORT=3007

# Database
MONGODB_URI=mongodb://localhost:27017/study_partner

# Auth service (used to resolve user emails from bearer tokens)
AUTH_SERVICE_URL=http://localhost:3001

# JWT (must match gateway/auth setup)
JWT_SECRET=change-me-to-a-secure-random-string

# Notification email delivery toggle
EMAIL_NOTIFICATIONS_ENABLED=false

# SMTP (used for engagement/notification emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=Study Partner <no-reply@study-partner.local>
