# Auth Service Environment Variables

# Server
NODE_ENV=development
PORT=3001

# Database (MongoDB)
MONGODB_URI=mongodb://localhost:27017/study_partner

# JWT — must match across all services
JWT_SECRET=change-me-to-a-secure-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Mail (Auth transactional emails: verification, reset, subscription reminders)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
EMAIL_FROM=Study Partner <noreply@studypartner.app>
APP_URL=http://localhost:5173

# Bcrypt
BCRYPT_ROUNDS=12

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
