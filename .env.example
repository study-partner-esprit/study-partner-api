# =============================================================================
# Study Partner API - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# NEVER commit the .env file to version control.
# =============================================================================

# --- Shared Secrets ---
JWT_SECRET=change-me-to-a-secure-random-string
MONGODB_URI=mongodb://host.docker.internal:27017/study_partner

# --- AI Service ---
GEMINI_API_KEY=your-gemini-api-key-here

# --- JWT ---
JWT_EXPIRES_IN=1h

# --- Logging ---
LOG_LEVEL=info

# --- Stripe ---
# Required for paid checkout endpoints
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Optional if using pre-created Stripe prices
STRIPE_PRICE_ID_VIP=
STRIPE_PRICE_ID_VIP_PLUS=
